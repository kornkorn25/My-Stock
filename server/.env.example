# Server port
PORT=4000

# Database (SQLite for easy start; swap provider in schema.prisma to move to Postgres)
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Finnhub API key (get a free key at https://finnhub.io)
FINNHUB_API_KEY="your-finnhub-key-here"

# Quote cache TTL in seconds (30-60 recommended)
QUOTE_CACHE_TTL=45

# CORS allowed origin (frontend dev server)
CLIENT_ORIGIN="http://localhost:5173"

# Public URL of this API server (used to build email verification links)
SERVER_PUBLIC_URL="http://localhost:4000"

# SMTP (optional). Leave SMTP_HOST empty to print verification links to the
# server console instead of sending real email (handy for local dev).
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="MyStock <no-reply@localhost>"

# Google OAuth (optional). Create an OAuth 2.0 Client ID (type: Web) in Google
# Cloud Console, add http://localhost:5173 as an authorized JavaScript origin,
# and paste the client ID here. Leave empty to hide the "Sign in with Google"
# button. No client secret is needed (we verify the ID token).
GOOGLE_CLIENT_ID=""
