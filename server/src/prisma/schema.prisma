// Prisma schema for MyStock.
// Uses PostgreSQL. Set DATABASE_URL to your Postgres connection string
// (Neon, Supabase, local Postgres, etc.). All money/share fields use Decimal
// to avoid floating point errors.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String? // null for Google-only accounts
  displayName   String
  emailVerified Boolean  @default(false)
  googleId      String?  @unique
  createdAt     DateTime @default(now())

  transactions       Transaction[]
  holdings           Holding[]
  verificationTokens VerificationToken[]
}

// One-time tokens for email-confirmed changes (email / password).
// payload holds the pending value: the new email, or the new bcrypt hash.
model VerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "EMAIL_CHANGE" | "PASSWORD_CHANGE"
  token     String   @unique
  payload   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Transaction {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol     String // stored uppercase, e.g. "PLTR"
  type       String // "BUY" | "SELL" (enum not supported on SQLite; validated via zod)
  quantity   Decimal // fractional shares supported, e.g. 0.12340000
  price      Decimal // price per share at execution
  fee        Decimal  @default(0)
  note       String?
  executedAt DateTime // user-specified execution datetime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, symbol])
}

model Holding {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String
  quantity    Decimal // current shares held
  avgCost     Decimal // average cost per share
  realizedPnl Decimal  @default(0) // realized P/L from sells
  targetPct   Decimal? // optional target allocation %, e.g. 25.00
  updatedAt   DateTime @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
}
